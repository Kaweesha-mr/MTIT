						}
					},
					"description": "Delete vehicle from fleet"
				},
				{
					"name": "Create Trip",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"vehicleId\": {{vehicleId}},\n    \"driverId\": {{volunteerId}},\n    \"cargoId\": {{resourceId}},\n    \"destinationId\": {{shelterId}}\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{baseUrl}}/trips",
							"host": ["{{baseUrl}}"],
							"path": ["trips"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.tripId) pm.collectionVariables.set(\"tripId\", jsonData.tripId);"
								]
							}
						}
					],
					"description": "Create trip with validation:\n✓ Vehicle must be AVAILABLE\n✓ Driver must have DRIVER role\n✓ Shelter must be OPEN status\n✗ Fails if shelter is REQUEST (not prepared yet)"
				},
				{
					"name": "Get Trips",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/trips",
							"host": ["{{baseUrl}}"],
							"path": ["trips"]
						}
					},
					"description": "List all trips with status"
				},
				{
					"name": "Get Trip By ID",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/trips/{{tripId}}",
							"host": ["{{baseUrl}}"],
							"path": ["trips", "{{tripId}}"]
						}
					},
					"description": "Get trip details including vehicle, driver, and destination"
				},
				{
					"name": "Update Trip Status",
					"request": {
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"IN_PROGRESS\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{baseUrl}}/trips/{{tripId}}",
							"host": ["{{baseUrl}}"],
							"path": ["trips", "{{tripId}}"]
						}
					},
					"description": "Update trip status (IN_PROGRESS, COMPLETED, CANCELLED)"
				},
				{
					"name": "Delete Trip",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{baseUrl}}/trips/{{tripId}}",
							"host": ["{{baseUrl}}"],
							"path": ["trips", "{{tripId}}"]
						}
					},
					"description": "Cancel/delete trip"
				}
			]
		}
	],
