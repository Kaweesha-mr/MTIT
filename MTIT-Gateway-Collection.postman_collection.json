					"name": "⏳ Get Shelter (REQUEST - Not Ready)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/shelters/{{shelterId}}",
							"host": ["{{baseUrl}}"],
							"path": ["shelters", "{{shelterId}}"]
						}
					},
					"description": "Check shelter status before admin preparation. Should show status=REQUEST and shelterLocation=null. Includes incidentLocation from the original incident."
				},
				{
					"name": "🏢 Update Shelter - Set Location & OPEN",
					"request": {
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"capacity\": 300,\n    \"location\": \"790 Oak St, Downtown\",\n    \"status\": \"OPEN\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{baseUrl}}/shelters/{{shelterId}}",
							"host": ["{{baseUrl}}"],
							"path": ["shelters", "{{shelterId}}"]
						}
					},
					"description": "Admin opens shelter near incident. Name field is optional (not required to update).\n\n1. Set shelter location near incident\n2. Adjust capacity\n3. Mark status as OPEN\n\nResponse includes both shelterLocation (what you set) and incidentLocation (original incident). After this, fleet can create trips with this shelter as destination"
				},
				{
					"name": "✅ Update Shelter - Back to REQUEST",
					"request": {
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
