				},
				{
					"name": "📋 View Gateway Logs",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						}
					},
					"description": "Gateway request logs are stored in container at: /var/log/gateway/requests.log\n\nView logs with:\n  docker exec mtit-gateway cat /var/log/gateway/requests.log\n  docker exec mtit-gateway tail -f /var/log/gateway/requests.log\n\nEach log entry shows: timestamp, method, path, service routed to, status, duration_ms, client_ip, cache_hit, rate_limited\n\nFormat: JSON (one entry per line)\nRotate: mv /var/log/gateway/requests.log /var/log/gateway/requests.log.old"
				}
			]
		},
