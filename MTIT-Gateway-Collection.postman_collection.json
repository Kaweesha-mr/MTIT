						"body": {
							"mode": "raw",
							"raw": "{\n    \"type\": \"FIRE\",\n    \"location\": \"123 Main St, Downtown\",\n    \"severity\": \"CRITICAL\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{baseUrl}}/incidents",
							"host": ["{{baseUrl}}"],
							"path": ["incidents"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.id) {",
									"    pm.collectionVariables.set(\"incidentId\", jsonData.id);",
									"}",
									"if(jsonData.downstream && jsonData.downstream.shelterId) {",
									"    pm.collectionVariables.set(\"shelterId\", jsonData.downstream.shelterId);",
									"}",
									"if(jsonData.downstream && jsonData.downstream.alertId) {",
									"    pm.collectionVariables.set(\"alertId\", jsonData.downstream.alertId);",
									"}"
								]
							}
						}
					],
					"description": "Creates incident and auto-triggers:\n✓ Alert (BROADCASTED)\n✓ Shelter (REQUEST status - needs admin prep)"
