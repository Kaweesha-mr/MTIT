# MTIT Platform - Root Environment Configuration
# This file is used by docker-compose for all services

# ============================================
# Environment: development | staging | production
# ============================================
ENVIRONMENT=development

# ============================================
# Database Credentials (for all databases)
# ============================================
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres_admin

MONGO_INITDB_ROOT_USERNAME=mongo_root
MONGO_INITDB_ROOT_PASSWORD=mongo_pass

REDIS_PASSWORD=

# ============================================
# Service Ports
# ============================================
GATEWAY_PORT=8080
AUTH_PORT=8090
INCIDENT_PORT=8081
VOLUNTEER_PORT=8082
ALERT_PORT=8085
RESOURCE_PORT=8083
SHELTER_PORT=8084
FLEET_PORT=8086

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
