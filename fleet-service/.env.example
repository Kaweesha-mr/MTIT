# Fleet Service Configuration
PORT=8086

# Database Configuration (MySQL)
DB_HOST=fleet-db
DB_PORT=3306
DB_USER=fleet_user
DB_PASSWORD=fleet_pass
DB_NAME=fleet_db

# Jaeger/Tracing
JAEGER_ENDPOINT=http://jaeger:4318

# Service URLs (internal calls)
VOLUNTEER_SERVICE_URL=http://volunteer-service:8082
RESOURCE_SERVICE_URL=http://resource-service:8083
SHELTER_SERVICE_URL=http://shelter-service:8084
