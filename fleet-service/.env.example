ENVIRONMENT=development
PORT=8086
LOG_LEVEL=info

# MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=mongo_root
MONGO_PASSWORD=mongo_pass
MONGO_DB=fleet_db
MONGO_URI=mongodb://mongo_root:mongo_pass@mongodb:27017/fleet_db

# External Services
RESOURCE_SERVICE_URL=http://resource-service:8083
VOLUNTEER_SERVICE_URL=http://volunteer-service:8082

# Tracing
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
