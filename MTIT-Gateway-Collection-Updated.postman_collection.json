			"item": [
				{
					"name": "Login (Get JWT Token)",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"change-me-now\"\n}",
							"options": {"raw": {"language": "json"}}
