						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"City Community Center\",\n    \"capacity\": 300,\n    \"location\": \"790 Oak St, Downtown\",\n    \"status\": \"OPEN\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{baseUrl}}/shelters/{{shelterId}}",
							"host": ["{{baseUrl}}"],
							"path": ["shelters", "{{shelterId}}"]
						}
					},
					"description": "Admin/Staff prepares shelter by:\n1. Setting exact location (near incident area)\n2. Adjusting capacity as needed\n3. Marking status as OPEN when ready"
				},
