						"url": {
							"raw": "{{baseUrl}}/login",
							"host": ["{{baseUrl}}"],
							"path": ["login"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": ["var jsonData = pm.response.json();\nif(jsonData.token) {\n    pm.collectionVariables.set(\"jwtToken\", jsonData.token);\n    console.log(\"JWT Token saved: \" + jsonData.token);\n}"]
							}
						}
					]
				}
			]
		},
		{
			"name": "WORKFLOW 1 - Create Incident & Auto-Create Shelter (REQUEST)",
			"item": [
				{
					"name": "🔴 1. Create Incident (ACTIVE)",
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{jwtToken}}", "type": "string"}]},
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"type\": \"FIRE\",\n    \"location\": \"789 Oak St\",\n    \"severity\": \"CRITICAL\"\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{baseUrl}}/incidents",
							"host": ["{{baseUrl}}"],
							"path": ["incidents"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": ["var jsonData = pm.response.json();\nif(jsonData.id) {\n    pm.collectionVariables.set(\"incidentId\", jsonData.id);\n    pm.collectionVariables.set(\"alertId\", jsonData.downstream.alertId);\n    pm.collectionVariables.set(\"shelterId\", jsonData.downstream.shelterId);\n    console.log(\"Incident: \" + jsonData.id + \", Alert: \" + jsonData.downstream.alertId + \", Shelter: \" + jsonData.downstream.shelterId);\n}"]
							}
						}
					]
				},
				{
					"name": "📊 2. Get Incident Details",
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{jwtToken}}", "type": "string"}]},
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/incidents/{{incidentId}}",
							"host": ["{{baseUrl}}"],
							"path": ["incidents", "{{incidentId}}"]
						}
					}
				},
				{
					"name": "⏳ 3. Get Shelter (REQUEST Status - Not Ready)",
					"request": {
						"auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{jwtToken}}", "type": "string"}]},
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/shelters/{{shelterId}}",
							"host": ["{{baseUrl}}"],
							"path": ["shelters", "{{shelterId}}"]
						}
					},
					"description": "Shelter is created in REQUEST status with null location. Must be prepared before trips can use it."
				}
			]
		},
