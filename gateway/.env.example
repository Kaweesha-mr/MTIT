ENVIRONMENT=development
PORT=8080
LOG_LEVEL=info

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Internal Service URLs
AUTH_SERVICE_URL=http://auth-service:8090
INCIDENT_SERVICE_URL=http://incident-service:8081
VOLUNTEER_SERVICE_URL=http://volunteer-service:8082
ALERT_SERVICE_URL=http://alert-service:8085
RESOURCE_SERVICE_URL=http://resource-service:8083
SHELTER_SERVICE_URL=http://shelter-service:8084
FLEET_SERVICE_URL=http://fleet-service:8086

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Tracing
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# CORS
CORS_ORIGIN=*
