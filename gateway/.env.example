# Gateway Configuration
PORT=8080

# Service URLs (internal service discovery)
INCIDENT_URL=http://incident-service:8081
VOLUNTEER_URL=http://volunteer-service:8082
RESOURCE_URL=http://resource-service:8083
SHELTER_URL=http://shelter-service:8084
ALERT_URL=http://alert-service:8085
FLEET_URL=http://fleet-service:8086
AUTH_SERVICE_URL=http://auth-service:8090

# Jaeger/Tracing
JAEGER_ENDPOINT=http://jaeger:4318

# Redis Cache
REDIS_ADDR=redis:6379
REDIS_DB=0

# Authentication limits
GATEWAY_AUTH_USER=admin
GATEWAY_AUTH_PASS=change-me-now
GATEWAY_JWT_SECRET=mtit-secure-secret-!
