# Incident Service Configuration
PORT=8081

# Database Configuration
DB_HOST=incident-db
DB_PORT=5432
DB_USER=incident_user
DB_PASSWORD=incident_pass
DB_NAME=incidents_db
DB_SSLMODE=disable

# Jaeger/Tracing
